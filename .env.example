# Assistant IA — au moins une clé (dev + Vercel)
# Groq : compte gratuit + quota généreux — https://console.groq.com/keys
GROQ_API_KEY=
# Optionnel (défaut : llama-3.1-8b-instant). Ex. : llama-3.3-70b-versatile
GROQ_CHAT_MODEL=llama-3.1-8b-instant
# Utilisé automatiquement si l’utilisateur envoie une photo / capture (Groq vision)
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# OpenAI : payant à l’usage (si vous ne mettez que Groq, laissez vide)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Si OPENAI_API_KEY et GROQ_API_KEY sont tous les deux remplis : forcer groq ou openai
# STAYPILOT_AI_PROVIDER=groq

# Désactiver le widget flottant : mettre false
# VITE_AI_CHAT_ENABLED=true

# E-mails transactionnels (résiliation) — expéditeur demandé
SUPPORT_FROM_EMAIL=support@staypilot.fr
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
