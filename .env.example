# Assistant IA — au moins une clé (dev + Vercel)
# Groq : compte gratuit + quota généreux — https://console.groq.com/keys
GROQ_API_KEY=
# Optionnel (défaut : llama-3.1-8b-instant). Ex. : llama-3.3-70b-versatile
GROQ_CHAT_MODEL=llama-3.1-8b-instant
# Utilisé automatiquement si l’utilisateur envoie une photo / capture (Groq vision)
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# OpenAI : payant à l’usage (si vous ne mettez que Groq, laissez vide)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Si OPENAI_API_KEY et GROQ_API_KEY sont tous les deux remplis : forcer groq ou openai
# STAYPILOT_AI_PROVIDER=groq

# Désactiver le widget flottant : mettre false
# VITE_AI_CHAT_ENABLED=true

# E-mails transactionnels (résiliation) — expéditeur demandé
SUPPORT_FROM_EMAIL=support@staypilot.fr
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Comptes partagés entre navigateurs (Vercel KV / Upstash Redis). Si vide : auth 100 % localStorage.
# Vercel : intégration KV ou variables fournies par le store Redis.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optionnel : purge distante POST /api/auth-purge-accounts (body JSON { "secret": "..." }), min. 16 caractères.
# STAYPILOT_PURGE_ACCOUNTS_SECRET=
# En dev, imposer le même comportement qu’en prod (pas de compte uniquement local) :
# VITE_REQUIRE_SERVER_ACCOUNTS=true

# Réserver un appel (Calendly + lien Meet)
VITE_CALENDLY_URL=
VITE_MEET_CALL_URL=
CALL_BOOKING_NOTIFY_TO=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
# Si true : ne pas remettre 14 j d’essai si l’e-mail a déjà un client Stripe avec un abonnement ayant eu une période d’essai (défaut : désactivé).
# STRIPE_TRIAL_STRICT_EMAIL_CHECK=true
# Public base URL for success/cancel redirects (ex: https://staypilot.fr)
APP_BASE_URL=
